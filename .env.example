# =============================================================
# Percival AgentMail MCP — environment template
# Copy this file to ".env" and fill in the real values.
# Never commit ".env" to version control.
# =============================================================

# AgentMail API key (obtain from https://agentmail.to)
AGENTMAIL_API_KEY=am_your_api_key_here

# Default inbox identifier used by all tools
AGENTMAIL_INBOX_ID=your_agent@agentmail.to

# Maximum results returned by list endpoints (default: 25, capped at 50)
AGENTMAIL_MAX_RESULTS=25

# HTTP timeout in seconds for AgentMail API calls (default: 30)
AGENTMAIL_TIMEOUT=30
